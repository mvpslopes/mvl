<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Não interceptar o app de finanças (subpasta com SPA própria)
  RewriteCond %{REQUEST_URI} ^/financas(/|$) [NC]
  RewriteRule ^ - [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(?!api/).*$ index.html [L]
</IfModule>
